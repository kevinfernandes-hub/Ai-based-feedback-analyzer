# Runtime
FLASK_ENV=production
PORT=5050
HOST=0.0.0.0
FLASK_DEBUG=0

# Required in production: set to a long random value
FLASK_SECRET_KEY=replace-with-a-long-random-secret

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Public form branding
BRAND_COLLEGE_NAME=Department of Computer Science and Engineering
BRAND_LOGO_URL=/static/img/logo.png
BRAND_PRIMARY_COLOR=#0f172a
BRAND_ACCENT_COLOR=#0c4a6e

# Optional AI configuration (set one provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

