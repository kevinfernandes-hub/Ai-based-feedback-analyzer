# Production Environment Variables Template
# Copy to /opt/feedback-app/.env and fill in your values
# DO NOT COMMIT THIS FILE TO GIT

# Flask Configuration
FLASK_ENV=production
FLASK_SECRET_KEY=<generate-with: python3 -c "import secrets; print(secrets.token_hex(32))">
HOST=127.0.0.1
PORT=5050

# Admin Credentials (required - change immediately after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<change-me-to-strong-password>

# AI Provider Configuration
# Can use either GEMINI or GROQ (not required to set both)

# Google Gemini API
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-1.5-flash

# Groq API (fallback provider)
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama3-8b-8192

# Branding
BRAND_COLLEGE_NAME=Your College Name
BRAND_LOGO_URL=/static/img/logo.png
# BRAND_PRIMARY_COLOR=#007bff
# BRAND_SECONDARY_COLOR=#6c757d

# Security
# Internal key for /metrics endpoint (generate: python3 -c "import secrets; print(secrets.token_hex(16))">
INTERNAL_METRICS_KEY=<random-internal-key>

# Database (optional - defaults to SQLite)
# For production with multiple workers, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/feedback_db

# Session Configuration
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600

# Rate Limiting
# Adjust based on expected load:
# RATE_LIMIT_GLOBAL=200 per day, 50 per hour
# RATE_LIMIT_CREATE_FORM=10 per minute
# RATE_LIMIT_SUBMIT_FEEDBACK=30 per hour

# Optional: Logging Level
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG  # For troubleshooting only

# Optional: Features
# ENABLE_AI_MAPPING=true
# ENABLE_MANUAL_MAPPING=true
# ENABLE_EXPORT_PDF=true

# Optional: Email (for future notifications)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=noreply@college.edu

# Optional: Monitoring (for third-party services)
# SENTRY_DSN=https://xxx@sentry.io/xxx
# DATADOG_API_KEY=xxx

# Security: Store sensitive values in a vault/secrets manager in production
# Do not hardcode production credentials
